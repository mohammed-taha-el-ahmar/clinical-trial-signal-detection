# ── Azure Event Hub ──────────────────────────────────────────────────────────
# Copy from Terraform output: simulator_connection_string
EVENTHUB_CONNECTION_STRING=Endpoint=sb://evhns-pharmasight-dev.servicebus.windows.net/;SharedAccessKeyName=simulator-sender;SharedAccessKey=...
EVENTHUB_NAME=adverse-events

# ── Azure Synapse Analytics ──────────────────────────────────────────────────
# Copy from Terraform output: synapse_sql_endpoint
SYNAPSE_SERVER=synw-pharmasight-dev.sql.azuresynapse.net
SYNAPSE_DATABASE=clinicaldw
SYNAPSE_USERNAME=sqladmin
SYNAPSE_PASSWORD=your-secure-password

# ── Signal detection tuning ──────────────────────────────────────────────────
SIGNAL_RATE_THRESHOLD=0.05
SIGNAL_WINDOW_MINUTES=10
SIGNAL_MIN_EVENTS=3

# ── Simulator ────────────────────────────────────────────────────────────────
SIMULATOR_EVENTS_PER_SECOND=2.0
SIMULATOR_SIGNAL_INJECTION_RATE=0.08

# ── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
